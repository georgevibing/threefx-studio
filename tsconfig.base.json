{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@threefx/core": ["packages/core/src/index.ts"],
      "@threefx/runtime": ["packages/runtime/src/index.ts"],
      "@threefx/exporter": ["packages/exporter/src/index.ts"],
      "@threefx/effects": ["packages/effects/src/index.ts"],
      "@threefx/ui": ["packages/ui/src/index.ts"]
    }
  }
}
